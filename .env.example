# Forge Dynamics Executive Crew — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# Stripe (read-only restricted key)
STRIPE_API_KEY=sk_test_your_stripe_test_key_here

# GitHub
GITHUB_TOKEN=github_pat_your_github_pat_here
GITHUB_REPO=arronstreet-ops/forge-dynamics-executive-crew

# Supabase (ai_ops schema only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# LLM via LiteLLM
LLM_MODEL=gemini/gemini-2.0-flash
GEMINI_API_KEY=your_gemini_api_key_here

# Multi-LLM eval harness (scripts/eval_marketing_agent.py)
# Uncomment and fill in to enable Claude + GPT red-team evaluation
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Cost controls
MONTHLY_COST_CEILING_USD=25.00
COST_ALERT_THRESHOLD_USD=15.00

# Runtime
USE_MOCKS=false
LOG_LEVEL=info

# Slack Webhooks (Phase 6)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/GENERAL/WEBHOOK
SLACK_WEBHOOK_DIGEST=https://hooks.slack.com/services/YOUR/DIGEST/WEBHOOK
SLACK_WEBHOOK_REDFLAG=https://hooks.slack.com/services/YOUR/REDFLAG/WEBHOOK
